# uv builds the virtualenv here (named via UV_PROJECT_ENVIRONMENT=venv);
# it's reproducible from uv.lock, so never committed.
venv/

__pycache__/
*.pyc

# Server user persisted by deploy.sh on first run — local to each box.
.deploy-user

# Per-box secrets and config: database URL, symbiot email, HMAC secret, Gmail.
# .env.example is the committed template; .env itself never is.
.env

# GCP service-account key for the Gmail API — a credential, never committed.
*.gmail.json
gmail-credentials*.json
*-sa-creds.json

