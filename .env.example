# Copy to `.env` and fill in.
# `.env` is gitignored and read at startup (config.py / load_dotenv),
# identically on a dev box and on the server —
# the only thing that differs between them is the values.

# --- database ---------------------------------------------------------------
# LOCAL (docker-compose): a TCP connection with a password.
DATABASE_URL=postgresql://joy:joy@localhost:5432/joy
# SERVER: leave DATABASE_URL pointing at the local Postgres via its unix socket,
# authenticated by peer auth (tied to the OS user the service runs as) —
# no host, no password.
# Create the database first as that user: `createdb $USER`.
# Then:
#   DATABASE_URL=postgresql:///$USER
# (Three slashes: empty host = default socket = peer auth as the current user.)

# The test suite uses its own database so it can truncate freely.
# Defaults to the DATABASE_URL's database with a `_test` suffix when unset.
# TEST_DATABASE_URL=postgresql://joy:joy@localhost:5432/joy_test

# --- identity ---------------------------------------------------------------
# The human symbiot seeded into the `symbiot` table at startup.
# Today the single seeded address; the schema and /login already support more than one,
# so this is the first symbiot, not the only one there can ever be.
SYMBIOT_EMAIL=you@example.com

# Server-side secret used to HMAC login codes and session tokens before they touch the database,
# so a DB leak never exposes a usable code or token.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
KERNEL_SECRET=change-me-in-production

# --- abuse limits (all overridable; defaults shown and already active) -------
# These are NOT opt-in: every limit below ships on, with the default baked into config.py.
# Uncomment a line only to override its default —
# leaving the whole block commented does not disable anything.
# Minimum gap between two issued codes for one symbiot — caps email bombing,
# and stops a double-tap from invalidating the code already in the inbox.
# LOGIN_REISSUE_INTERVAL_SECONDS=60
# Wrong guesses a single live code absorbs before the database burns it.
# MAX_VERIFY_ATTEMPTS=5
# The edge rate limiter; on unless set to 0/false/no/off.
# The only limit here that can be switched fully off —
# the DB guarantees above stay enforced regardless.
# Behind nginx it needs `proxy_set_header X-Real-IP $remote_addr;` to key per-caller.
# RATE_LIMIT_ENABLED=true

# --- email (Gmail API) ------------------------------------------------------
# When these are unset the real client refuses to send;
# the test suite uses an in-memory fake instead.
# Path to the GCP service-account JSON key (gitignored;
# lives outside the repo or alongside it but never committed).
GMAIL_CREDENTIALS_FILE=
# The Workspace mailbox the service account impersonates / sends as.
GMAIL_SENDER=

# --- persona ----------------------------------------------------------------
# The machine symbiot's voice, kept as two files (persona.py).
# The public half is versioned in the repo (persona/public.md) and holds the character;
# the private half (persona/private.md) is gitignored and holds what stays between you and your symbiot, 
# spliced into the {{ INJECT_SYMBIOSIS_CORE_PRIVATE }} slot of the public half.
# Both default to those repo paths; set these only to point them elsewhere.
# An absent private file is fine — the slot collapses and the public persona stands alone.
# PERSONA_PUBLIC_FILE=persona/public.md
# PERSONA_PRIVATE_FILE=persona/private.md

# --- web push (VAPID) -------------------------------------------------------
# The signing key for kernel-originated push notifications (the reply channel).
# When unset, the kernel simply sends no pushes —
# answers still store and /answers still serves them; only the tap-on-the-shoulder is skipped.
# The private key is the raw 32-octet scalar in base64url;
# the public application server key the browser subscribes with is derived from it at runtime,
# so only the private half is configured. Generate a pair with:
#   uv run python -c "import base64;from cryptography.hazmat.primitives.asymmetric import ec;k=ec.generate_private_key(ec.SECP256R1());print(base64.urlsafe_b64encode(k.private_numbers().private_value.to_bytes(32,'big')).decode().rstrip('='))"
VAPID_PRIVATE_KEY=
# A contact URI the push service can reach the app owner at (mailto: or https:).
VAPID_SUBJECT=mailto:you@example.com

# --- ontology router (Ollama) -----------------------------------------------
# The router embeds and re-ranks locally — no external inference API, the same
# sovereignty stance as the rest of the kernel — so these point at the host's Ollama.
# Every key below ships with a working default baked into config.py;
# uncomment one only to override it. A fresh clone routes with zero of these set.
# Where the local Ollama listens.
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# The embedding model the router routes with.
# Its 768-wide output is what the ontology_embedding_nomic_embed_text tables are typed to,
# and it must match the model seeded active in embedding_model (migration 0010) —
# change one without the other and facts are searched against vectors from a different model.
# EMBEDDING_MODEL=nomic-embed-text
# The context window opened on every embed call.
# Ollama clips nomic-embed-text to 2048 tokens by default and truncates in silence;
# 8192 is the model's native window, so a long text reaches its vector whole.
# EMBEDDING_NUM_CTX=8192
# How long to wait on an embed call — generous, since the first call after a cold load pays the load once.
# OLLAMA_TIMEOUT_SECONDS=60
# The generative model behind the router's judgments (re-rank now, tie-break / mint / JSON-LD later).
# RERANK_MODEL=qwen3.5:4b
# How long to wait on a generative call — longer than an embed, still inside the intake deadline.
# LLM_TIMEOUT_SECONDS=120
# How wide a candidate pool the vector search hands the re-ranker —
# wide for recall, but no wider than the re-ranker can weigh well in one call,
# not as wide as the index could answer.
# RECALL_POOL=20
# The HNSW working-set width per query.
# Must stay >= RECALL_POOL, or recall is capped below the pool we ask back.
# RECALL_EF_SEARCH=100
# The two thresholds that band the top re-rank score into reuse / grey / mint.
# At or above REUSE_THRESHOLD the top type is reused; at or below MINT_THRESHOLD a new type is coined;
# the band between them escalates to the one-shot LLM gate.
# INVARIANT: 0.0 <= MINT_THRESHOLD < REUSE_THRESHOLD <= 1.0.
# Cross them and the kernel refuses to boot rather than silently mis-file every fact that follows.
# REUSE_THRESHOLD=0.7
# MINT_THRESHOLD=0.3

# --- ontology duplicate GC (offline, in-process) ----------------------------
# The sweep that collapses the semantic-duplicate types lazy minting breeds over time.
# It runs in-process on a slow cadence like the intake reconcile sweep — no external cron.
# On unless set to 0/false/no/off (the tests turn it off to drive the merge by hand).
# GC_ENABLED=true
# How often the sweep wakes. A day, not seconds — duplicates accrue slowly and this is off the read path.
# GC_SWEEP_INTERVAL_SECONDS=86400
# The cosine-distance pre-filter for nominating near-twin type pairs before the model confirms them.
# A loose net, not the verdict; widen it to catch synonyms that embed further apart.
# The by-hand smoke (test/qa/0002_ontology_gc_smoke.py) prints real distances to tune this against.
# GC_DISTANCE=0.2
